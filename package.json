{
  "name": "pi-extensions",
  "private": false,
  "type": "module",
  "description": "Monorepo of high-quality Pi coding agent extensions published to npm and the pi.dev gallery.",
  "homepage": "https://github.com/jmcombs/pi-extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmcombs/pi-extensions.git"
  },
  "bugs": {
    "url": "https://github.com/jmcombs/pi-extensions/issues"
  },
  "license": "MIT",
  "author": "Jeremy Combs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome check --linter-enabled=false --assist-enabled=false .",
    "typecheck": "node scripts/typecheck.mjs",
    "test": "vitest run",
    "security:secrets": "secretlint \"**/*\"",
    "security:audit": "npm audit --omit=dev",
    "security": "npm run security:secrets && npm run security:audit",
    "sync-versions": "node scripts/sync-versions.mjs",
    "check:versions": "node scripts/sync-versions.mjs --check",
    "check": "npm run lint && npm run typecheck && npm run test && npm run check:versions && npm run security",
    "update:1p-plugins": "tsx scripts/update-1p-shell-plugins.ts",
    "check:1p-plugins": "tsx scripts/update-1p-shell-plugins.ts --check",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "*",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/node": "^24.13.3",
    "husky": "^9.1.7",
    "secretlint": "^13.0.2",
    "tsx": "^4.23.1",
    "typebox": "^1.3.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
