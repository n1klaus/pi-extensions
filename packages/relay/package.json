{
  "name": "@jmcombs/pi-relay",
  "version": "0.0.0",
  "description": "Relay roles for Pi: run any Pi subagent on an external coding agent (headless Claude Opus via `claude -p`) through a provider seam, driven by the subagent's `model` field.",
  "homepage": "https://github.com/jmcombs/pi-extensions/tree/main/packages/relay",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmcombs/pi-extensions.git",
    "directory": "packages/relay"
  },
  "bugs": {
    "url": "https://github.com/jmcombs/pi-extensions/issues"
  },
  "license": "MIT",
  "author": "Jeremy Combs",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "files": [
    "index.ts",
    "provider.ts",
    "drivers/",
    "roles/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "claude",
    "opus",
    "agent-dispatch",
    "verify",
    "async"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/jmcombs/pi-extensions/main/assets/relay/preview.png"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
